# lean-hooks environment variables
# Copy this file to .env in your project root or set globally.
# Only required if auto-detection fails.

# Path to Python 3.8+ interpreter (used by harness scripts)
# If unset, harness will try: $HARNESS_PYTHON > python3 > python
# HARNESS_PYTHON=/usr/bin/python3.11

# Root directory for harness config (default: parent of harness/ directory)
# After install.sh, this is typically ~/.claude or $CLAUDE_CONFIG_DIR
# HARNESS_ROOT=$HOME/.claude

# Path to Chromium/Chrome executable (used by health-check.sh)
# If unset, health-check.sh skips the Chromium check
# CHROME_EXE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Path to agent-browser binary (used by health-check.sh)
# If unset, defaults to $HARNESS_ROOT/runtime/npm/node_modules/agent-browser/bin/agent-browser-win32-x64.exe
# AGENT_BROWSER_BIN=/opt/agent-browser/bin/agent-browser

# Comma-separated list of hooks to temporarily disable
# DISABLED_HOOKS=multiagent-detect,post-task-detect
